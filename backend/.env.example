# ==========================================
# BACKEND (Django + Celery) Environment Variables
# These must be set in your Railway dashboard for the backend services
# ==========================================

# Database Connection (Provided by your Cloud Postgres provider)
DB_HOST=your-postgres-host.up.railway.app
DB_NAME=playto_db
DB_USER=playto_user
DB_PASSWORD=your_secure_password
DB_PORT=5432

# Redis Connection (Provided by your Cloud Redis provider)
REDIS_URL=redis://your-redis-url.up.railway.app:6379/0
