# BACKEND (Django + Celery) Environment Variables
# Set these in your Render (or Railway/Fly) dashboard for the backend service

# Database Connection (Example for Render Free Postgres)
DB_HOST=dpg-crabcdefghijk1234567-a.oregon-postgres.render.com
DB_NAME=playto_db
DB_USER=playto_user
DB_PASSWORD=your_secure_password
DB_PORT=5432

# Redis Connection (Example for Upstash Free Redis)
REDIS_URL=rediss://default:your_secure_password@your-endpoint.upstash.io:6379
